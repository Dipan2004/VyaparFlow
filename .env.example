# ============================================================
# NotiFlow Autonomous — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── NVIDIA NIM (Primary LLM Backend) ────────────────────────
# Get your API key at: https://integrate.api.nvidia.com
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# Optional: override the default model or endpoint
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct

# ── Google Gemini (Fallback LLM) ────────────────────────────
# Used automatically if NIM is unavailable
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets Ledger ─────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS=credentials/sheets.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Feature Flags ────────────────────────────────────────────
# Set to false to use live NIM inference instead of demo data
NOTIFLOW_DEMO_MODE=true

# ── Optional: Custom Excel path ──────────────────────────────
# EXCEL_FILE_PATH=/path/to/custom/notiflow_data.xlsx
